# Local runs use application-local.yml by default.
# Use these variables only when you want to override the local defaults.
DB_URL=jdbc:mysql://127.0.0.1:3306/family_tree_showcase?useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_general_ci&serverTimezone=Asia/Shanghai&useSSL=false&autoReconnect=true&failOverReadOnly=false
DB_USERNAME=root
DB_PASSWORD=change-me

JWT_SECRET=change-me-before-production

WECHAT_MINIAPP_APP_ID=YOUR_MINIAPP_APP_ID
WECHAT_MINIAPP_SECRET=YOUR_MINIAPP_SECRET

TENCENT_COS_SECRET_ID=YOUR_TENCENT_COS_SECRET_ID
TENCENT_COS_SECRET_KEY=YOUR_TENCENT_COS_SECRET_KEY
TENCENT_COS_BUCKET=your-bucket-appid
TENCENT_COS_CDN_URL=https://example.com
