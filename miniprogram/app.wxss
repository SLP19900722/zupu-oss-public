/**App.wxss**/
page {
  background-color: #FFF8DC;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', STHeiti, 'Microsoft Yahei', Tahoma, Simsun, sans-serif;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 中国风装饰边框 */
.chinese-border {
  border: 2rpx solid #C8161D;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(200, 22, 29, 0.1);
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, #FFF8DC 0%, #F5E6D3 100%);
}

/* 主色调按钮 */
.primary-btn {
  background-color: #C8161D;
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
}

.primary-btn:active {
  opacity: 0.8;
}

/* 次要按钮 */
.secondary-btn {
  background-color: #FFFFFF;
  color: #C8161D;
  border: 2rpx solid #C8161D;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

/* 副标题 */
.subtitle {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

/* 文本 */
.text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 中国结装饰 */
.chinese-knot {
  width: 60rpx;
  height: 60rpx;
  background-image: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMjUiIGZpbGw9IiNDODE2MUQiLz48L3N2Zz4=');
  background-size: contain;
}

/* Loading样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
  color: #C8161D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  color: #999999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
}
