.history-page {
  min-height: 100vh;
  padding: 28rpx;
  background:
    radial-gradient(circle at top, rgba(199, 154, 71, 0.16), transparent 30%),
    linear-gradient(180deg, #f6eee2 0%, #f4eadf 54%, #fbf7f1 100%);
}

.hero-card,
.list-card,
.notice-item,
.empty-card {
  border-radius: 30rpx;
  border: 1rpx solid rgba(172, 96, 68, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(79, 50, 32, 0.08);
}

.hero-card {
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 58%, #c79a47 100%);
}

.hero-kicker,
.hero-title,
.hero-desc,
.hero-meta-label,
.hero-meta-value {
  display: block;
}

.hero-kicker {
  color: rgba(255, 244, 230, 0.82);
  font-size: 20rpx;
  letter-spacing: 6rpx;
}

.hero-title {
  margin-top: 12rpx;
  color: #fff8f0;
  font-size: 42rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 10rpx;
  color: rgba(255, 245, 232, 0.92);
  font-size: 24rpx;
}

.hero-meta-card {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 240, 0.14);
}

.hero-meta-label {
  color: rgba(255, 245, 232, 0.86);
  font-size: 20rpx;
}

.hero-meta-value {
  margin-top: 10rpx;
  color: #fff8f0;
  font-size: 24rpx;
  line-height: 1.7;
}

.list-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 252, 247, 0.96);
}

.list-head,
.notice-item-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.section-title {
  display: block;
  color: #2f241b;
  font-size: 34rpx;
  font-weight: 700;
}

.section-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7769;
  font-size: 22rpx;
  line-height: 1.7;
}

.mini-btn {
  min-width: 116rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(143, 31, 31, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-btn-text {
  color: #8f1f1f;
  font-size: 20rpx;
  font-weight: 700;
}

.notice-list {
  margin-top: 24rpx;
}

.notice-item {
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 242, 0.96) 100%);
}

.notice-item + .notice-item {
  margin-top: 16rpx;
}

.notice-item.active {
  border-color: rgba(143, 31, 31, 0.22);
  box-shadow: 0 18rpx 42rpx rgba(143, 31, 31, 0.12);
}

.notice-item-title {
  display: block;
  color: #2f241b;
  font-size: 28rpx;
  font-weight: 700;
}

.notice-item-meta,
.notice-item-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7769;
  font-size: 22rpx;
  line-height: 1.7;
}

.notice-item-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(143, 31, 31, 0.08);
  color: #8f1f1f;
  font-size: 20rpx;
}

.empty-card {
  margin-top: 24rpx;
  padding: 48rpx 28rpx;
  text-align: center;
  background: rgba(255, 252, 247, 0.96);
}

.empty-title {
  display: block;
  color: #2f241b;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #8a7769;
  font-size: 22rpx;
  line-height: 1.7;
}
