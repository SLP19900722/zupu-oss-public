.legal-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top right, rgba(199, 154, 71, 0.16), transparent 26%),
    linear-gradient(180deg, #F8F0E5 0%, #F4E9DD 52%, #FBF7F1 100%);
}

.hero-card,
.highlight-card,
.section-card {
  border-radius: 28rpx;
  border: 1rpx solid rgba(172, 96, 68, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(79, 50, 32, 0.1);
}

.hero-card {
  padding: 34rpx 30rpx;
  background: linear-gradient(145deg, #8F1F1F 0%, #B44E39 52%, #C79A47 100%);
}

.hero-kicker {
  color: rgba(255, 239, 214, 0.88);
  font-size: 22rpx;
  letter-spacing: 6rpx;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  color: #FFF8F0;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
  font-family: "Songti SC", "STSong", "PingFang SC", serif;
}

.hero-meta {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 243, 224, 0.88);
  font-size: 22rpx;
}

.hero-summary {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 248, 240, 0.94);
  font-size: 25rpx;
  line-height: 1.7;
}

.highlight-grid {
  margin-top: 20rpx;
}

.highlight-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 248, 239, 0.94) 100%);
}

.highlight-label {
  color: #8F1F1F;
  font-size: 24rpx;
  font-weight: 700;
}

.highlight-value {
  display: block;
  margin-top: 12rpx;
  color: #675547;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-card {
  margin-top: 20rpx;
  padding: 28rpx 26rpx;
  background: rgba(255, 252, 247, 0.95);
}

.section-heading-row {
  display: flex;
  align-items: center;
}

.section-index {
  width: 42rpx;
  height: 42rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8F1F1F 0%, #C06B53 100%);
  color: #FFF8F0;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-heading {
  flex: 1;
  color: #2F241B;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  font-family: "Songti SC", "STSong", "PingFang SC", serif;
}

.section-paragraph {
  display: block;
  margin-top: 18rpx;
  color: #68584C;
  font-size: 25rpx;
  line-height: 1.8;
}

.bullet-list {
  margin-top: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  margin-top: 14rpx;
}

.bullet-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8F1F1F 0%, #C79A47 100%);
  flex-shrink: 0;
}

.bullet-text {
  flex: 1;
  color: #68584C;
  font-size: 25rpx;
  line-height: 1.8;
}
