.add-page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(180rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top, rgba(199, 154, 71, 0.16), transparent 32%),
    linear-gradient(180deg, #f6eee2 0%, #f4eadf 54%, #fbf7f1 100%);
}

.hero-card,
.section-card {
  border-radius: 30rpx;
  border: 1rpx solid rgba(172, 96, 68, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(79, 50, 32, 0.08);
}

.hero-card {
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 58%, #c79a47 100%);
}

.hero-kicker,
.hero-title,
.hero-desc,
.hero-pill-text {
  color: #fff8f0;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 244, 230, 0.82);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 240, 0.16);
}

.hero-pill-text {
  font-size: 22rpx;
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 252, 247, 0.96);
}

.section-kicker {
  display: block;
  color: #9a6e47;
  font-size: 20rpx;
  letter-spacing: 6rpx;
}

.section-title {
  display: block;
  margin-top: 10rpx;
  color: #2f241b;
  font-size: 34rpx;
  font-weight: 700;
  font-family: "Songti SC", "STSong", "PingFang SC", serif;
}

.section-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7769;
  font-size: 24rpx;
  line-height: 1.7;
}

.avatar-uploader {
  position: relative;
  height: 240rpx;
  margin-top: 22rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fffdf9 0%, #fff7ee 100%);
  border: 2rpx dashed rgba(172, 96, 68, 0.26);
}

.avatar-uploader.has-image {
  border-style: solid;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-overlay {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 11, 10, 0.56);
}

.avatar-overlay-text {
  color: #fff8f0;
  font-size: 22rpx;
}

.avatar-empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-empty-plus {
  position: relative;
  width: 82rpx;
  height: 82rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(143, 31, 31, 0.12) 0%, rgba(199, 154, 71, 0.18) 100%);
}

.plus-line {
  position: absolute;
  background: #8f1f1f;
  border-radius: 999rpx;
}

.plus-line.vertical {
  top: 22rpx;
  left: 39rpx;
  width: 4rpx;
  height: 38rpx;
}

.plus-line.horizontal {
  top: 39rpx;
  left: 22rpx;
  width: 38rpx;
  height: 4rpx;
}

.avatar-empty-title {
  display: block;
  margin-top: 18rpx;
  color: #2f241b;
  font-size: 30rpx;
  font-weight: 700;
}

.avatar-empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7769;
  font-size: 22rpx;
}

.field-grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

.field-block {
  margin-top: 20rpx;
}

.field-block.half {
  width: 324rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #7d6a5d;
  font-size: 24rpx;
}

.field-input,
.field-picker,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  border-radius: 22rpx;
  border: 1rpx solid rgba(172, 96, 68, 0.12);
  background: linear-gradient(180deg, #fffdf9 0%, #fff7ee 100%);
  color: #2f241b;
  font-size: 26rpx;
}

.field-input,
.field-picker {
  min-height: 96rpx;
  padding: 28rpx 24rpx;
}

.field-textarea {
  min-height: 220rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  line-height: 1.8;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(246, 238, 226, 0.92);
  backdrop-filter: blur(12rpx);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 100%);
  box-shadow: 0 18rpx 30rpx rgba(143, 31, 31, 0.18);
}

.submit-btn.is-disabled {
  opacity: 0.6;
}

.submit-btn-text {
  color: #fff8f0;
  font-size: 28rpx;
  font-weight: 700;
}
