.upload-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6eee2 0%, #fbf7f1 100%);
  padding: 28rpx 28rpx 48rpx;
}

.hero-card,
.upload-card {
  border-radius: 30rpx;
  border: 1rpx solid rgba(172, 96, 68, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(79, 50, 32, 0.08);
}

.hero-card {
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 60%, #c79a47 100%);
}

.hero-kicker {
  display: block;
  color: rgba(255, 244, 230, 0.82);
  font-size: 20rpx;
  letter-spacing: 6rpx;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  color: #fff8f0;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 246, 238, 0.92);
  font-size: 24rpx;
  line-height: 1.7;
}

.upload-card {
  margin-top: 24rpx;
  padding: 30rpx 26rpx 34rpx;
  background: rgba(255, 252, 247, 0.96);
}

.field-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.field-title {
  color: #2f241b;
  font-size: 32rpx;
  font-weight: 700;
}

.field-tip {
  color: #9a8677;
  font-size: 22rpx;
}

.image-panel {
  position: relative;
  height: 440rpx;
  margin-top: 22rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #fff6ed 0%, #fffdf9 100%);
  border: 2rpx dashed rgba(199, 154, 71, 0.36);
}

.image-panel.has-image {
  border: none;
  box-shadow: 0 16rpx 30rpx rgba(79, 50, 32, 0.12);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(20, 12, 10, 0.52);
}

.image-overlay-text {
  color: #fff7ee;
  font-size: 22rpx;
}

.image-empty {
  height: 100%;
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.image-empty-plus {
  width: 90rpx;
  height: 90rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #c79a47 100%);
  position: relative;
}

.plus-line {
  position: absolute;
  background: #fff8f0;
  border-radius: 999rpx;
}

.plus-line.vertical {
  width: 6rpx;
  height: 36rpx;
  top: 27rpx;
  left: 42rpx;
}

.plus-line.horizontal {
  width: 36rpx;
  height: 6rpx;
  top: 42rpx;
  left: 27rpx;
}

.image-empty-title {
  display: block;
  margin-top: 22rpx;
  color: #2f241b;
  font-size: 32rpx;
  font-weight: 700;
}

.image-empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #8f7c6e;
  font-size: 24rpx;
  line-height: 1.7;
}

.field-block {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  color: #5d493c;
  font-size: 24rpx;
  font-weight: 600;
}

.field-input,
.field-textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #fffdf9;
  border: 1rpx solid rgba(193, 161, 123, 0.22);
  box-sizing: border-box;
  color: #2f241b;
  font-size: 26rpx;
}

.field-textarea {
  min-height: 180rpx;
}

.submit-btn {
  height: 94rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 28rpx rgba(143, 31, 31, 0.18);
}

.submit-btn.is-disabled {
  opacity: 0.7;
}

.submit-btn-text {
  color: #fff8f0;
  font-size: 30rpx;
  font-weight: 700;
}
