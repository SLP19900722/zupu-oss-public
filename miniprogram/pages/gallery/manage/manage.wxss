.manage-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6eee2 0%, #fbf7f1 100%);
  padding: 28rpx 28rpx 48rpx;
}

.hero-card,
.tab-row,
.gallery-item,
.empty-card {
  border-radius: 30rpx;
  border: 1rpx solid rgba(172, 96, 68, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(79, 50, 32, 0.08);
}

.hero-card {
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 60%, #c79a47 100%);
}

.hero-kicker,
.hero-title,
.hero-desc,
.hero-action-text {
  color: #fff8f0;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 244, 230, 0.82);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  padding: 0 26rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 240, 0.18);
}

.hero-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.tab-row {
  display: flex;
  align-items: center;
  padding: 12rpx;
  margin-top: 24rpx;
  background: rgba(255, 252, 247, 0.96);
}

.tab-item {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 100%);
  box-shadow: 0 12rpx 24rpx rgba(143, 31, 31, 0.12);
}

.tab-text {
  color: #7b6659;
  font-size: 24rpx;
  font-weight: 600;
}

.tab-item.active .tab-text {
  color: #fff8f0;
}

.gallery-list {
  margin-top: 24rpx;
}

.gallery-item {
  display: flex;
  padding: 20rpx;
  background: rgba(255, 252, 247, 0.96);
}

.gallery-item + .gallery-item {
  margin-top: 18rpx;
}

.gallery-thumb {
  width: 220rpx;
  height: 220rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.gallery-info {
  flex: 1;
  margin-left: 18rpx;
}

.gallery-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gallery-item-title {
  max-width: 320rpx;
  color: #2f241b;
  font-size: 30rpx;
  font-weight: 700;
}

.gallery-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.gallery-status.pending {
  color: #8f1f1f;
  background: rgba(143, 31, 31, 0.08);
}

.gallery-status.published {
  color: #1a8459;
  background: rgba(26, 132, 89, 0.1);
}

.gallery-status.rejected {
  color: #bc5640;
  background: rgba(188, 86, 64, 0.1);
}

.gallery-item-desc {
  display: block;
  margin-top: 12rpx;
  color: #8f7c6e;
  font-size: 22rpx;
  line-height: 1.6;
}

.gallery-item-time,
.gallery-item-remark {
  display: block;
  margin-top: 10rpx;
  color: #a08d7f;
  font-size: 20rpx;
  line-height: 1.5;
}

.gallery-actions {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.gallery-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 100%);
}

.gallery-btn.light {
  background: rgba(143, 31, 31, 0.08);
}

.gallery-btn.reject {
  background: rgba(188, 86, 64, 0.12);
}

.gallery-btn.gold {
  background: rgba(199, 154, 71, 0.16);
}

.gallery-btn.danger {
  background: linear-gradient(135deg, #8f1f1f 0%, #a12824 100%);
}

.gallery-btn-text {
  color: #fff8f0;
  font-size: 22rpx;
  font-weight: 700;
}

.gallery-btn-text.dark {
  color: #8f1f1f;
}

.gallery-btn-text.reject-text {
  color: #bc5640;
}

.gallery-btn-text.gold-text {
  color: #9a6e22;
}

.empty-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  background: rgba(255, 252, 247, 0.96);
  text-align: center;
}

.empty-mark {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(143, 31, 31, 0.12) 0%, rgba(199, 154, 71, 0.18) 100%);
}

.empty-title {
  display: block;
  margin-top: 18rpx;
  color: #2f241b;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #8f7c6e;
  font-size: 24rpx;
  line-height: 1.7;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 28rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8f1f1f 0%, #bc5640 100%);
}

.empty-btn-text {
  color: #fff8f0;
  font-size: 24rpx;
  font-weight: 700;
}
