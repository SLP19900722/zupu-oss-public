@keyframes locatePulseGlow {
  0% {
    box-shadow: 0 8rpx 18rpx rgba(154, 119, 79, 0.08), 0 0 0 0 rgba(226, 87, 52, 0.12);
  }

  40% {
    box-shadow: 0 22rpx 42rpx rgba(214, 66, 47, 0.24), 0 0 0 10rpx rgba(214, 66, 47, 0.12);
  }

  72% {
    box-shadow: 0 24rpx 44rpx rgba(241, 172, 78, 0.26), 0 0 0 14rpx rgba(241, 172, 78, 0.1);
  }

  100% {
    box-shadow: 0 10rpx 20rpx rgba(154, 119, 79, 0.08), 0 0 0 0 rgba(241, 172, 78, 0);
  }
}

@keyframes locatePulseScale {
  0%,
  100% {
    transform: scale(1);
  }

  40% {
    transform: scale(1.08);
  }

  72% {
    transform: scale(1.04);
  }
}

@keyframes locatePulseScaleOverview {
  0%,
  100% {
    transform: scale(1);
  }

  40% {
    transform: scale(1.05);
  }

  72% {
    transform: scale(1.025);
  }
}

@keyframes locatePulseTint {
  0%,
  100% {
    border-color: rgba(204, 44, 39, 0.94);
    background: linear-gradient(180deg, rgba(255, 247, 245, 1) 0%, rgba(255, 240, 234, 0.98) 100%);
  }

  50% {
    border-color: rgba(241, 172, 78, 0.98);
    background: linear-gradient(180deg, rgba(255, 250, 239, 1) 0%, rgba(255, 241, 214, 0.98) 100%);
  }
}

@keyframes locateBannerLift {
  0% {
    opacity: 0;
    transform: translateY(-18rpx) scale(0.98);
  }

  18% {
    opacity: 1;
    transform: translateY(0) scale(1.02);
  }

  70% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  100% {
    opacity: 0.98;
    transform: translateY(0) scale(1);
  }
}

@keyframes locateBannerSweep {
  0% {
    transform: translateX(0) rotate(18deg);
    opacity: 0;
  }

  18% {
    opacity: 0.84;
  }

  100% {
    transform: translateX(360%) rotate(18deg);
    opacity: 0;
  }
}

@keyframes locateBadgePop {
  0%,
  100% {
    transform: scale(1);
  }

  45% {
    transform: scale(1.06);
  }
}

@keyframes locateCalloutPop {
  0% {
    opacity: 0;
    transform: translateY(10rpx) scale(0.9);
  }

  22% {
    opacity: 1;
    transform: translateY(-4rpx) scale(1.03);
  }

  52% {
    transform: translateY(0) scale(0.99);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes locateCalloutBreath {
  0%,
  100% {
    box-shadow: 0 30rpx 54rpx rgba(177, 40, 33, 0.28), 0 0 0 10rpx rgba(255, 208, 112, 0.14);
  }

  50% {
    box-shadow: 0 38rpx 66rpx rgba(177, 40, 33, 0.36), 0 0 0 14rpx rgba(255, 208, 112, 0.2);
  }
}

@keyframes overviewOrbFloat {
  0%,
  100% {
    transform: translateY(0) scale(1);
    opacity: 0.78;
  }

  50% {
    transform: translateY(-16rpx) scale(1.06);
    opacity: 0.9;
  }
}

@keyframes overviewSelfAura {
  0%,
  100% {
    box-shadow: 0 16rpx 28rpx rgba(189, 78, 55, 0.16), 0 0 0 0 rgba(255, 180, 116, 0.12);
  }

  50% {
    box-shadow: 0 22rpx 40rpx rgba(198, 86, 61, 0.24), 0 0 0 10rpx rgba(255, 186, 126, 0.24);
  }
}

@keyframes overviewSelfAuraStrong {
  0%,
  100% {
    box-shadow: 0 22rpx 42rpx rgba(200, 22, 29, 0.2), 0 0 0 8rpx rgba(255, 174, 110, 0.11);
  }

  50% {
    box-shadow: 0 28rpx 52rpx rgba(202, 42, 34, 0.28), 0 0 0 14rpx rgba(255, 184, 122, 0.26);
  }
}

@keyframes overviewSceneEnter {
  0% {
    opacity: 0.72;
    transform: translateY(10rpx) scale(0.97);
    filter: saturate(0.9);
  }

  55% {
    opacity: 1;
    transform: translateY(-2rpx) scale(1.01);
    filter: saturate(1.04);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: saturate(1);
  }
}

@keyframes overviewSceneFocus {
  0% {
    transform: scale(0.985);
    filter: brightness(1) saturate(1);
  }

  45% {
    transform: scale(1.012);
    filter: brightness(1.03) saturate(1.05);
  }

  100% {
    transform: scale(1);
    filter: brightness(1) saturate(1);
  }
}

@keyframes locateTriggerPulse {
  0%,
  100% {
    box-shadow: 0 10rpx 22rpx rgba(200, 22, 29, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
  }

  50% {
    box-shadow: 0 16rpx 30rpx rgba(200, 22, 29, 0.28), 0 0 0 8rpx rgba(255, 177, 111, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.32);
  }
}

