.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(200, 22, 29, 0.14) 0, rgba(200, 22, 29, 0) 24%),
    radial-gradient(circle at left top, rgba(255, 199, 92, 0.16) 0, rgba(255, 199, 92, 0) 24%),
    linear-gradient(180deg, #fff8f1 0%, #fff1e1 100%);
  padding: 14rpx;
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 246, 234, 0.98) 100%);
  border: 1rpx solid rgba(231, 214, 188, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(140, 94, 56, 0.12);
  overflow: hidden;
}

.hero-card.compact {
  gap: 14rpx;
  padding: 14rpx 18rpx;
  min-height: 90rpx;
}

.hero-glow {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 205, 145, 0.34) 0%, rgba(255, 205, 145, 0) 72%);
}

.hero-badge {
  position: relative;
  z-index: 1;
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #c8161d 0%, #f36a41 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 700;
  font-family: 'KaiTi', 'STKaiti', serif;
  box-shadow: 0 12rpx 28rpx rgba(200, 22, 29, 0.3);
}

.hero-card.compact .hero-badge {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  box-shadow: 0 8rpx 20rpx rgba(200, 22, 29, 0.24);
}

.hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.hero-copy.compact {
  display: flex;
  align-items: center;
}

.hero-summary {
  display: block;
  width: 100%;
  font-size: 26rpx;
  font-weight: 700;
  color: #5f4739;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2e221d;
  letter-spacing: 4rpx;
  font-family: 'KaiTi', 'STKaiti', serif;
}

.hero-meta,
.hero-sub {
  display: block;
  margin-top: 6rpx;
}

.hero-meta {
  font-size: 23rpx;
  color: #8f7664;
}

.hero-sub {
  font-size: 21rpx;
  line-height: 1.6;
  color: #a07d61;
}

.hero-action {
  position: relative;
  z-index: 1;
  width: 116rpx;
  min-height: 86rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #fffaf2 0%, #ffeed8 100%);
  border: 1rpx solid rgba(227, 207, 182, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8), 0 10rpx 20rpx rgba(169, 124, 76, 0.14);
}

.hero-action.bind {
  background: linear-gradient(135deg, #c8161d 0%, #e34f43 100%);
  border-color: rgba(200, 22, 29, 0.92);
}

.hero-action-main {
  font-size: 24rpx;
  font-weight: 700;
  color: #7e5d44;
}

.hero-action-sub {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #b28f6b;
}

.hero-action.bind .hero-action-main,
.hero-action.bind .hero-action-sub {
  color: #fff;
}

.notice-card,
.tree-shell,
.section-card,
.tree-board-shell,
.classic-panel,
.empty-panel,
.side-group-panel {
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98) 0%, rgba(255, 247, 236, 0.98) 100%);
  border: 1rpx solid rgba(235, 218, 191, 0.82);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.notice-card {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.notice-card.select-mode {
  background: linear-gradient(135deg, rgba(255, 246, 238, 0.98) 0%, rgba(255, 251, 245, 0.98) 100%);
  border-color: rgba(232, 188, 164, 0.88);
}

.notice-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7a614d;
}

.notice-link {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #c8161d;
}

.tree-shell {
  margin-top: 14rpx;
  padding: 20rpx;
  box-shadow: 0 20rpx 48rpx rgba(142, 94, 55, 0.14);
}

.view-toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.view-switch {
  flex: 1;
  display: grid;
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(255, 247, 236, 0.9);
  border: 1rpx solid rgba(233, 215, 188, 0.7);
  box-sizing: border-box;
}

.view-switch {
  grid-template-columns: 1fr 1fr;
}

.view-switch-item {
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #8b6d54;
}

.view-switch-item.active {
  color: #fff;
  background: linear-gradient(135deg, #c8161d 0%, #ff6146 100%);
  box-shadow: 0 10rpx 22rpx rgba(200, 22, 29, 0.22);
}

.summary-row,
.tree-toolbar,
.expand-actions,
.tree-node-actions,
.classic-actions,
.overview-actions {
  display: flex;
  gap: 12rpx;
}

.summary-row {
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.summary-chip {
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 241, 0.98);
  border: 1rpx solid rgba(230, 213, 184, 0.8);
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #8c715a;
}

.summary-chip.primary {
  color: #a53a2a;
  border-color: rgba(230, 170, 139, 0.9);
  background: linear-gradient(135deg, rgba(255, 244, 241, 0.98) 0%, rgba(255, 249, 243, 0.98) 100%);
}

.summary-chip.locate {
  color: #9b381d;
  border-color: rgba(240, 140, 92, 0.9);
  background: linear-gradient(135deg, rgba(255, 243, 235, 0.98) 0%, rgba(255, 248, 240, 0.98) 100%);
}

.locate-banner {
  position: relative;
  overflow: hidden;
  margin-top: 14rpx;
  padding: 18rpx 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(232, 171, 137, 0.86);
  background: linear-gradient(135deg, rgba(255, 246, 238, 0.98) 0%, rgba(255, 238, 228, 0.98) 52%, rgba(255, 250, 241, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(200, 22, 29, 0.14);
  animation: locateBannerLift 1.8s ease-out 1 both;
}

.locate-banner.spouse {
  border-color: rgba(224, 152, 98, 0.82);
  background: linear-gradient(135deg, rgba(255, 248, 239, 0.98) 0%, rgba(255, 239, 226, 0.98) 50%, rgba(255, 247, 234, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(212, 122, 58, 0.14);
}

.locate-banner-beam {
  position: absolute;
  top: -34rpx;
  left: -24%;
  width: 34%;
  height: calc(100% + 68rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.78) 50%, rgba(255, 255, 255, 0) 100%);
  transform: rotate(18deg);
  opacity: 0.88;
  animation: locateBannerSweep 1.35s ease-out 1;
}

.locate-banner-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.locate-banner-kicker {
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 2rpx;
  color: #b44b2f;
  font-weight: 700;
}

.locate-banner-text {
  font-size: 28rpx;
  line-height: 1.45;
  color: #872318;
  font-weight: 700;
}

.locate-callout {
  position: absolute;
  z-index: 8;
  pointer-events: none;
  box-sizing: border-box;
  padding: 18rpx 22rpx 20rpx;
  border-radius: 26rpx;
  border: 2rpx solid rgba(255, 214, 122, 0.96);
  background: linear-gradient(145deg, rgba(207, 30, 31, 0.98) 0%, rgba(236, 87, 51, 0.98) 48%, rgba(255, 174, 74, 0.98) 100%);
  box-shadow: 0 28rpx 54rpx rgba(178, 37, 34, 0.28), 0 0 0 10rpx rgba(255, 197, 92, 0.16);
  overflow: visible;
  animation: locateCalloutPop 1.8s cubic-bezier(0.18, 0.88, 0.24, 1) 1 both;
}

.locate-callout.compact {
  padding: 16rpx 20rpx 18rpx;
  border-radius: 22rpx;
}

.locate-callout.spouse {
  border-color: rgba(255, 225, 168, 0.94);
  background: linear-gradient(145deg, rgba(183, 92, 28, 0.98) 0%, rgba(234, 133, 52, 0.98) 54%, rgba(255, 205, 112, 0.98) 100%);
  box-shadow: 0 26rpx 52rpx rgba(158, 94, 30, 0.24), 0 0 0 10rpx rgba(255, 208, 122, 0.16);
}

.locate-callout-glow {
  position: absolute;
  inset: -16rpx;
  border-radius: 34rpx;
  background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.44) 0%, rgba(255, 255, 255, 0) 54%);
  opacity: 0.92;
}

.locate-callout-kicker,
.locate-callout-text {
  position: relative;
  z-index: 1;
  display: block;
  color: #fffdf7;
}

.locate-callout-kicker {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 3rpx;
  text-shadow: 0 2rpx 8rpx rgba(118, 19, 18, 0.24);
}

.locate-callout-text {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.42;
  font-weight: 700;
  text-shadow: 0 4rpx 12rpx rgba(118, 19, 18, 0.22);
}

.locate-callout.compact .locate-callout-text {
  font-size: 24rpx;
}

.locate-callout.compact.overview-pop {
  padding: 22rpx 26rpx 24rpx;
  border-radius: 28rpx;
  border-color: rgba(255, 222, 142, 0.96);
  background: linear-gradient(145deg, rgba(206, 34, 33, 0.98) 0%, rgba(236, 98, 53, 0.98) 52%, rgba(255, 193, 88, 0.98) 100%);
  box-shadow: 0 34rpx 58rpx rgba(177, 40, 33, 0.34), 0 0 0 12rpx rgba(255, 208, 112, 0.18);
  animation: locateCalloutPop 1.8s cubic-bezier(0.18, 0.88, 0.24, 1) 1 both, locateCalloutBreath 2.8s ease-in-out infinite;
}

.locate-callout.compact.overview-pop.spouse {
  background: linear-gradient(145deg, rgba(181, 92, 28, 0.98) 0%, rgba(233, 136, 56, 0.98) 56%, rgba(255, 210, 124, 0.98) 100%);
  border-color: rgba(255, 226, 170, 0.95);
  box-shadow: 0 34rpx 58rpx rgba(156, 96, 33, 0.28), 0 0 0 12rpx rgba(255, 216, 140, 0.16);
}

.locate-callout.compact.overview-pop .locate-callout-kicker {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 10rpx rgba(109, 19, 16, 0.34);
}

.locate-callout.compact.overview-pop .locate-callout-text {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.34;
  text-shadow: 0 4rpx 16rpx rgba(118, 18, 16, 0.34);
}

.locate-callout.compact.overview-pop .locate-callout-glow {
  inset: -20rpx;
  border-radius: 40rpx;
  background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.52) 0%, rgba(255, 255, 255, 0.04) 58%, rgba(255, 255, 255, 0) 76%);
}

.locate-callout.compact.overview-pop .locate-callout-arrow {
  border-radius: 10rpx;
  box-shadow: 0 8rpx 14rpx rgba(165, 45, 33, 0.22);
}

.locate-callout-arrow {
  position: absolute;
  z-index: 0;
  border-radius: 8rpx;
  background: inherit;
  border-right: inherit;
  border-bottom: inherit;
  transform: rotate(45deg);
}

.mini-btn,
.expand-btn,
.tiny-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-weight: 700;
}

.mini-btn,
.expand-btn.ghost,
.tiny-btn.ghost {
  background: linear-gradient(135deg, #fffaf2 0%, #ffefd9 100%);
  border: 1rpx solid rgba(225, 201, 171, 0.88);
  color: #8b6648;
}

.mini-btn {
  flex-shrink: 0;
  min-width: 132rpx;
  min-height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.mini-btn.locate-trigger {
  min-width: 172rpx;
  min-height: 76rpx;
  font-size: 28rpx;
  color: #fff;
  border-color: rgba(209, 60, 43, 0.86);
  background: linear-gradient(135deg, #c8161d 0%, #f05a3f 62%, #ffb267 100%);
  box-shadow: 0 10rpx 22rpx rgba(200, 22, 29, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
  animation: locateTriggerPulse 2.4s ease-in-out infinite;
}

.expand-actions {
  margin-top: 16rpx;
}

.expand-btn {
  flex: 1;
  min-height: 74rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #c8161d 0%, #ef5d43 100%);
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(200, 22, 29, 0.16);
}

.tiny-btn {
  min-width: 84rpx;
  min-height: 44rpx;
  padding: 0 14rpx;
  font-size: 20rpx;
  background: linear-gradient(135deg, #c8161d 0%, #ef5d43 100%);
  color: #fff;
}

.section-card,
.side-group-panel,
.tree-board-shell,
.classic-panel {
  margin-top: 18rpx;
  padding: 20rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-head.slim {
  align-items: center;
}

.section-title,
.side-group-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #33251e;
}

.section-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #96765e;
  line-height: 1.6;
}

.focus-tag {
  min-width: 88rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe5c4 100%);
  border: 1rpx solid rgba(223, 186, 124, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9a6b34;
  font-size: 22rpx;
  font-weight: 700;
}

.side-group-title {
  font-size: 24rpx;
}

.side-group-scroll {
  margin-top: 14rpx;
}

.side-group-row {
  display: flex;
  gap: 12rpx;
}

.side-chip {
  flex: 0 0 auto;
  min-width: 160rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 250, 244, 0.98);
  border: 1rpx solid rgba(234, 219, 195, 0.8);
}

.side-chip-name {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a3529;
  max-width: 260rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.side-chip-spouse {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #a17c5d;
  max-width: 260rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.overview-view {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  padding: 14rpx 0 0;
}

.overview-atmosphere {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
  overflow: hidden;
  border-radius: 30rpx;
  z-index: 0;
  opacity: 0.72;
  background:
    radial-gradient(circle at 18% 14%, rgba(255, 214, 154, 0.14) 0%, rgba(255, 214, 154, 0) 48%),
    radial-gradient(circle at 82% 84%, rgba(255, 190, 140, 0.12) 0%, rgba(255, 190, 140, 0) 50%),
    linear-gradient(180deg, rgba(255, 251, 244, 0.52) 0%, rgba(255, 246, 236, 0.42) 100%);
}
.overview-orb {
  position: absolute;
  border-radius: 50%;
  opacity: 0.78;
  animation: overviewOrbFloat 11s ease-in-out infinite;
}

.overview-orb-a {
  width: 360rpx;
  height: 360rpx;
  right: -110rpx;
  top: -84rpx;
  background: radial-gradient(circle, rgba(255, 214, 152, 0.42) 0%, rgba(255, 214, 152, 0) 68%);
}

.overview-orb-b {
  width: 320rpx;
  height: 320rpx;
  left: -96rpx;
  bottom: -82rpx;
  background: radial-gradient(circle, rgba(255, 187, 143, 0.34) 0%, rgba(255, 187, 143, 0) 72%);
  animation-delay: -3.8s;
}

.overview-orb-c {
  width: 220rpx;
  height: 220rpx;
  left: 34%;
  top: 24%;
  background: radial-gradient(circle, rgba(255, 236, 196, 0.34) 0%, rgba(255, 236, 196, 0) 74%);
  animation-delay: -6.2s;
}

.tree-board-shell.overview {
  position: relative;
  z-index: 2;
  margin-top: 16rpx;
  border-width: 2rpx;
  border-color: rgba(224, 188, 150, 0.74);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 252, 247, 0.98) 100%);
  box-shadow: 0 18rpx 36rpx rgba(170, 117, 74, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
  transform-origin: center top;
  transition: transform 220ms ease, opacity 220ms ease, filter 220ms ease;
}

.tree-board-shell.overview.overview-stage {
  margin-top: 0;
  border-radius: 28rpx;
}
.tree-board-shell.overview.overview-scene-enter {
  animation: overviewSceneEnter 280ms cubic-bezier(0.2, 0.8, 0.25, 1) 1 both;
}

.tree-board-shell.overview.overview-scene-focus {
  animation: overviewSceneFocus 300ms cubic-bezier(0.2, 0.82, 0.26, 1) 1 both;
}

.tree-scroll-y {
  max-height: 1280rpx;
}

.overview-scroll-y,
.overview-scroll-x {
  overflow: hidden;
}

.overview-scroll-y {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid rgba(228, 197, 161, 0.68);
}

.tree-board-shell.overview .tree-edge {
  background: rgba(205, 122, 74, 0.68);
}

.tree-board-shell.overview .tree-edge.highlight {
  background: rgba(205, 66, 42, 0.92);
  box-shadow: 0 0 14rpx rgba(205, 66, 42, 0.24);
}

.overview-scroll-x {
  border-radius: 24rpx;
}

.overview-scale-shell {
  position: relative;
  overflow: visible;
}

.overview-transient-layer {
  position: relative;
  transform-origin: 0 0;
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
}

.overview-scale-layer {
  position: relative;
  transform-origin: 0 0;
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
}

.tree-canvas {
  position: relative;
}

.tree-gen-label {
  position: absolute;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 250, 241, 0.96) 0%, rgba(255, 241, 220, 0.96) 100%);
  border: 1rpx solid rgba(225, 201, 171, 0.74);
  color: #8c6647;
  font-size: 19rpx;
  font-weight: 700;
}

.tree-edge {
  position: absolute;
  background: rgba(221, 190, 144, 0.46);
  z-index: 1;
}

.tree-edge.highlight {
  background: rgba(214, 92, 56, 0.86);
  box-shadow: 0 0 10rpx rgba(214, 92, 56, 0.14);
}

.tree-node {
  position: absolute;
  z-index: 2;
  box-sizing: border-box;
  padding: 8rpx 10rpx 8rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 241, 0.98) 100%);
  border: 1rpx solid rgba(231, 214, 188, 0.88);
  box-shadow: 0 6rpx 16rpx rgba(154, 119, 79, 0.06);
}

.tree-node.related {
  border-color: rgba(236, 194, 122, 0.9);
}

.tree-node.self {
  border-color: rgba(200, 22, 29, 0.48);
}

.tree-node.focus {
  border-color: rgba(200, 22, 29, 0.86);
  box-shadow: 0 18rpx 34rpx rgba(200, 22, 29, 0.16);
  background: linear-gradient(180deg, rgba(255, 248, 246, 1) 0%, rgba(255, 243, 238, 0.98) 100%);
}

.tree-node.locate-pulse {
  z-index: 6;
  will-change: transform, box-shadow, border-color;
  border-color: rgba(226, 87, 52, 0.96);
  box-shadow: 0 18rpx 36rpx rgba(200, 22, 29, 0.22), 0 0 0 12rpx rgba(255, 171, 76, 0.16);
  animation: locatePulseGlow 0.78s ease-in-out 2, locatePulseScale 0.78s ease-in-out 2, locatePulseTint 0.78s linear 2;
}

.tree-node.self.locate-pulse {
  border-color: rgba(200, 22, 29, 0.96);
}

.tree-node.focus.locate-pulse {
  box-shadow: 0 24rpx 44rpx rgba(200, 22, 29, 0.28), 0 0 0 14rpx rgba(240, 110, 60, 0.18);
}

.tree-node.group.locate-pulse {
